{
	"name": "@ts-drp/routing-browser",
	"version": "0.11.0",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/drp-tech/ts-drp.git"
	},
	"type": "module",
	"types": "./dist/src/index.d.ts",
	"files": [
		"src",
		"dist",
		"!dist/test",
		"!**/*.tsbuildinfo"
	],
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"import": "./dist/src/index.js"
		}
	},
	"scripts": {
		"build": "tsc -b tsconfig.build.json",
		"clean": "rm -rf dist/ node_modules/",
		"prepack": "tsc -b",
		"test": "pnpm --dir ../.. exec vitest run packages/routing-browser/tests",
		"typecheck": "tsc --noEmit",
		"watch": "tsc -b -w"
	},
	"dependencies": {
		"@helia/delegated-routing-v1-http-api-client": "8.0.1",
		"@libp2p/interface": "3.2.5",
		"@libp2p/logger": "6.2.7",
		"@libp2p/peer-id": "6.0.12",
		"@ts-drp/rendezvous": "workspace:*",
		"multiformats": "14.0.0"
	},
	"devDependencies": {
		"esbuild": "0.25.3",
		"vitest": "^3.0.5"
	}
}
