{
	"network_config": {
		"bootstrap_peers": [],
		"listen_addresses": ["/ip4/127.0.0.1/tcp/50010/ws"],
		"control_plane": {
			"address_policy": {
				"allowInsecureWebSocket": true,
				"allowLoopback": true,
				"target": "node"
			},
			"membership": {
				"invite": { "inviteToken": "grid-local-fixture-invite-0123456789" },
				"mode": "invite"
			},
			"recovery": {
				"backend_cooldown_ms": 1000,
				"health_poll_interval_ms": 250,
				"max_attempts": 3,
				"parent_deadline_ms": 10000,
				"recovery_backoff_ms": 250,
				"retry_delays_ms": [0, 250, 500],
				"startup_grace_ms": 1500
			},
			"rendezvous": {
				"allow_insecure_loopback_fixture": true,
				"endpoints": [
					"http://127.0.0.1:4175/grid-registry/primary",
					"http://127.0.0.1:4175/grid-registry/secondary"
				],
				"namespace": "drp-network:v1:Z2F0ZS03LWxvY2FsLWZpeHR1cmU",
				"publish": true,
				"record_ttl_ms": 60000,
				"refresh_interval_ms": 1000
			},
			"rollout": {
				"public_components": {
					"public_rendezvous": { "enabled": true }
				}
			},
			"routing": {
				"node": {
					"bootstrappers": [],
					"enabled": true,
					"network": "local"
				}
			}
		},
		"log_config": { "level": "info" }
	},
	"keychain_config": {
		"private_key_seed": "grid-modular-local-publisher"
	}
}
